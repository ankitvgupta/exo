# Local-only env vars — NEVER commit `.env.local` itself.
# Copy this file to `.env.local` and fill in the values.
#
# `.env.local` is gitignored and lives only on the developer's machine.
# CI never has access to any of these.

# ---- Anthropic API ----
# Used by: tests/evals/runner.ts (LLM-judge), scripts/agentic-verify.mjs,
# scripts/spike-agent-sdk.mjs, and any other local script that calls Claude.
# Not used by the packaged app or by Claude Code (which manages its own auth).
ANTHROPIC_API_KEY=

# ---- Gmail OAuth for exoemailtest@gmail.com ----
# Used by: scripts/seed-test-inbox.mjs, tests/real-gmail/* (when implemented).
# These authenticate as the dedicated test account — NEVER the user's real
# inbox.
#
# To obtain a refresh token: run `node scripts/seed-test-inbox.mjs` once
# with EXOEMAILTEST_CLIENT_ID and EXOEMAILTEST_CLIENT_SECRET set but the
# refresh token blank. The script prints a consent URL and a code prompt.
# After completing the flow, it prints the refresh token — paste it here.
#
# The OAuth client itself can be the same one used for the app dev flow,
# as long as exoemailtest@gmail.com is added as a test user on the OAuth
# consent screen.
EXOEMAILTEST_CLIENT_ID=
EXOEMAILTEST_CLIENT_SECRET=
EXOEMAILTEST_REFRESH_TOKEN=
